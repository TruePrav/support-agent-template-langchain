# ============================================================
# .env.example -- Copy this to .env and fill in your values
# ============================================================
# NEVER commit .env to GitHub -- it contains secret keys
# Add .env to your .gitignore (it's already there in this template)
# ============================================================

# ── LLM Provider ─────────────────────────────────────────────
# Which AI company to use. Options: "openai" or "anthropic"
# Recommendation: start with "openai" (easier setup)
MODEL_PROVIDER=openai

# OpenAI API key (get it at platform.openai.com/api-keys)
# Starts with "sk-"
OPENAI_API_KEY=sk-proj-...

# OpenAI model to use (gpt-4o-mini is cheap and fast -- good for support)
OPENAI_MODEL=gpt-4o-mini

# Anthropic (Claude) -- only needed if MODEL_PROVIDER=anthropic
# Get key at console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5

# Temperature: controls how creative/random the responses are
# 0.0 = always the same answer, 1.0 = very random
# 0.3 = slightly varied but consistent -- recommended for support agents
TEMPERATURE=0.3

# ── Telegram ──────────────────────────────────────────────────
# Your bot token -- get it from @BotFather on Telegram
# Steps: open Telegram → search @BotFather → /newbot → follow prompts → copy token
# Looks like: 7123456789:AAFabcdef...
TELEGRAM_BOT_TOKEN=

# Your personal Telegram chat ID -- escalation alerts are sent here
# Steps: open Telegram → message @userinfobot → it replies with your ID
# Looks like: 123456789
ESCALATION_CHAT_ID=

# ── Database (for persistent memory) ─────────────────────────
# Postgres connection string -- the agent stores conversation history here
# We recommend Supabase (free): supabase.com → New Project → Settings → Database → URI
# Replace [YOUR-PASSWORD] with your actual Supabase database password
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.YOURPROJECT.supabase.co:5432/postgres

# Leave DATABASE_URL blank to use in-memory storage (conversations reset on restart)
# In-memory mode is fine for testing -- use Postgres for production
# DATABASE_URL=

# ── Memory ────────────────────────────────────────────────────
# How many previous messages the agent remembers per user
# 20 is a good default -- enough context without slowing down
MEMORY_WINDOW=20

# ── Rate Limiting ─────────────────────────────────────────────
# Max messages a single user can send per minute
# Prevents spam and protects your OpenAI bill
# Default: 10 -- increase if your customers send fast multi-part messages
RATE_LIMIT_PER_MINUTE=10

# ── Meta (WhatsApp / Instagram / Messenger) ───────────────────
# Only needed if using meta_bot.py -- skip if using Telegram only

# Permanent token from: Meta Developer Dashboard → Your App → WhatsApp → API Setup
WHATSAPP_TOKEN=

# Phone Number ID from: Meta Developer Dashboard → Your App → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=

# Any string you choose -- must match exactly what you set in the Meta webhook dashboard
# Example: mysecretverifytoken123
META_VERIFY_TOKEN=
